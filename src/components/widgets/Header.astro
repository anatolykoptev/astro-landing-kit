---
/**
 * @deprecated Use `astro-landing-kit/ui/Header` instead.
 *
 * This widget is now a thin wrapper around the ui/Header primitive.
 * It forwards all props and preserves the id="header" default for
 * backward compatibility with BasicScripts.astro (which is hardcoded
 * to the #header ID). New consumers should import ui/Header directly.
 */
import Header from '~/components/ui/Header.astro';

import type { CallToAction, MenuLink } from '~/types';

export interface Props {
  id?: string;
  links?: Array<MenuLink>;
  actions?: Array<CallToAction>;
  isSticky?: boolean;
  isDark?: boolean;
  isFullWidth?: boolean;
  showToggleTheme?: boolean;
  showRssFeed?: boolean;
  position?: string;
  navAriaLabel?: string;
  toggleMenuLabel?: string;
  rssAriaLabel?: string;
}

const {
  id = 'header',
  links = [],
  actions = [],
  isSticky = false,
  isDark = false,
  isFullWidth = false,
  showToggleTheme = false,
  showRssFeed = false,
  position = 'center',
  navAriaLabel = 'Main navigation',
  toggleMenuLabel,
  rssAriaLabel = 'RSS Feed',
} = Astro.props;
---

<Header
  id={id}
  links={links}
  actions={actions}
  isSticky={isSticky}
  isDark={isDark}
  isFullWidth={isFullWidth}
  showToggleTheme={showToggleTheme}
  showRssFeed={showRssFeed}
  position={position}
  navAriaLabel={navAriaLabel}
  toggleMenuLabel={toggleMenuLabel}
  rssAriaLabel={rssAriaLabel}
  showSkipLink={false}
/>
