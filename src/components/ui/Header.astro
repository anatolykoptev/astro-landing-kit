---
/**
 * ui/Header — exportable navigation primitive (2026-grade).
 *
 * Extracted from widgets/Header.astro via strangler-fig. Key differences:
 * - Uses data-aw-header attribute (NOT id="header") to avoid CSS/JS conflict
 *   with the widget during coexistence.
 * - Skip link as first focusable element (WCAG 2.4.1 bypass block).
 * - Slots for brand, actions, theme-toggle with DEFAULT content so consumers
 *   don't MUST provide them.
 * - autoGenerateBlogLinks prop triggers generateBlogNavLinks() utility.
 * - Scoped <script> for mobile menu toggle (NOT is:inline, NOT BasicScripts).
 * - Basic keyboard: tab, focus-visible, Enter/Space, Escape (close mobile menu).
 *
 * @deprecated widgets/Header.astro — use ui/Header instead.
 */
import { Icon } from 'astro-icon/components';
import Logo from '~/components/Logo.astro';
import ThemeToggle from '~/components/islands/ThemeToggle.svelte';
import ToggleMenu from '~/components/common/ToggleMenu.astro';
import Button from '~/components/ui/Button.astro';

import { getHomePermalink } from '~/utils/permalinks';
import { trimSlash, getAsset } from '~/utils/permalinks';
import { generateBlogNavLinks } from '~/utils/navigation';
import type { CallToAction, MenuLink } from '~/types';

export interface Props {
  id?: string;
  links?: Array<MenuLink>;
  actions?: Array<CallToAction>;
  isSticky?: boolean;
  isDark?: boolean;
  isFullWidth?: boolean;
  showToggleTheme?: boolean;
  showRssFeed?: boolean;
  showSkipLink?: boolean;
  skipLinkTarget?: string;
  position?: string;
  navAriaLabel?: string;
  toggleMenuLabel?: string;
  rssAriaLabel?: string;
  autoGenerateBlogLinks?: boolean;
}

const {
  id,
  links: manualLinks = [],
  actions = [],
  isSticky = false,
  isDark = false,
  isFullWidth = false,
  showToggleTheme = false,
  showRssFeed = false,
  showSkipLink = true,
  skipLinkTarget = '#main-content',
  position = 'center',
  navAriaLabel = 'Main navigation',
  toggleMenuLabel,
  rssAriaLabel = 'RSS Feed',
  autoGenerateBlogLinks = false,
} = Astro.props;

const currentPath = `/${trimSlash(new URL(Astro.url).pathname)}`;

// Merge auto-generated blog links with manual links
const allLinks = autoGenerateBlogLinks
  ? [...generateBlogNavLinks(), ...manualLinks]
  : manualLinks;
---

{showSkipLink && (
  <a
    href={skipLinkTarget}
    class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[60] focus:px-4 focus:py-2 focus:bg-primary focus:text-on-primary focus:rounded focus:text-sm focus:font-semibold"
  >
    Skip to main content
  </a>
)}

<header
  class:list={[
    { sticky: isSticky, relative: !isSticky, dark: isDark },
    'top-0 z-40 flex-none mx-auto w-full border-b border-hairline transition-[opacity] ease-in-out',
    isSticky && 'backdrop-blur-md bg-page/80',
  ]}
  data-aw-header
  {...isSticky ? { 'data-aw-sticky-header': true } : {}}
  {...id ? { id } : {}}
>
  <div
    class:list={[
      'relative text-default py-3 px-3 md:px-6 mx-auto w-full',
      {
        'md:flex md:justify-between': position !== 'center',
      },
      {
        'md:grid md:grid-cols-3 md:items-center': position === 'center',
      },
      {
        'max-w-7xl': !isFullWidth,
      },
    ]}
  >
    <div class:list={[{ 'mr-auto rtl:mr-0 rtl:ml-auto': position === 'right' }, 'flex justify-between']}>
      <a class="flex items-center" href={getHomePermalink()}>
        <slot name="brand">
          <Logo />
        </slot>
      </a>
      <div class="flex items-center md:hidden">
        <ToggleMenu label={toggleMenuLabel} />
      </div>
    </div>
    <nav
      class="items-center w-full md:w-auto hidden md:flex md:mx-5 text-default overflow-y-auto overflow-x-hidden md:overflow-visible md:justify-self-center"
      aria-label={navAriaLabel}
    >
      <ul
        class="flex flex-col md:flex-row md:self-center w-full md:w-auto text-xl md:text-sm tracking-tight font-medium md:justify-center"
      >
        {
          allLinks.map(({ text, href, links, ariaLabel }) => (
            <li class={links?.length ? 'dropdown' : ''}>
              {links?.length ? (
                <>
                  <button
                    type="button"
                    class="hover:text-primary px-4 py-3 flex items-center whitespace-nowrap transition-colors"
                  >
                    {text}{' '}
                    <Icon name="tabler:chevron-down" class="w-3.5 h-3.5 ml-0.5 rtl:ml-0 rtl:mr-0.5 hidden md:inline" />
                  </button>
                  <ul class="dropdown-menu md:backdrop-blur-md rounded md:absolute pl-4 md:pl-0 md:hidden font-medium md:bg-card/95 md:min-w-[200px] drop-shadow-xl border border-hairline">
                    {links.map(({ text: text2, href: href2, ariaLabel: ariaLabel2 }) => (
                      <li>
                        <a
                          class:list={[
                            'first:rounded-t last:rounded-b md:hover:bg-surface hover:text-primary py-2 px-5 block whitespace-nowrap transition-colors',
                            { 'aw-link-active': href2 === currentPath },
                          ]}
                          href={href2}
                          aria-label={ariaLabel2}
                        >
                          {text2}
                        </a>
                      </li>
                    ))}
                  </ul>
                </>
              ) : (
                <a
                  class:list={[
                    'hover:text-primary px-4 py-3 flex items-center whitespace-nowrap transition-colors',
                    { 'aw-link-active': href === currentPath },
                  ]}
                  href={href}
                  aria-label={ariaLabel}
                >
                  {text}
                </a>
              )}
            </li>
          ))
        }
      </ul>
    </nav>
    <div
      class:list={[
        { 'ml-auto rtl:ml-0 rtl:mr-auto': position === 'left' },
        'hidden md:self-center md:flex items-center md:mb-0 fixed w-full md:w-auto md:static justify-end left-0 rtl:left-auto rtl:right-0 bottom-0 p-3 md:p-0 md:justify-self-end',
      ]}
    >
      <div class="items-center flex justify-between w-full md:w-auto gap-3">
        <div class="flex items-center gap-2">
          <slot name="theme-toggle">
            {showToggleTheme && <ThemeToggle client:load />}
          </slot>
          {
            showRssFeed && (
              <a
                class="text-muted hover:text-default hover:bg-surface focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/40 rounded-lg text-sm p-2 inline-flex items-center transition-colors"
                aria-label={rssAriaLabel}
                href={getAsset('/rss.xml')}
              >
                <Icon name="tabler:rss" class="w-5 h-5" />
              </a>
            )
          }
        </div>
        <slot name="actions">
          {
            actions?.length ? (
              <span class="ml-2 rtl:ml-0 rtl:mr-2">
                {actions.map((btnProps) => (
                  <Button {...btnProps} class="ml-2 py-2.5 px-5 md:px-6 font-semibold shadow-none text-sm w-auto" />
                ))}
              </span>
            ) : (
              ''
            )
          }
        </slot>
      </div>
    </div>
  </div>
</header>

<script>
  // Mobile menu toggle — scoped to [data-aw-header], does NOT touch #header
  // (BasicScripts.astro owns #header for the legacy widget wrapper).
  // Skip if this element also has id="header" — BasicScripts handles it.
  const header = document.querySelector('[data-aw-header]');
  if (header && header.id !== 'header') {
    const toggle = header.querySelector('[data-aw-toggle-menu]');
    if (toggle) {
      toggle.addEventListener('click', () => {
        header.classList.toggle('expanded');
        const expanded = header.classList.contains('expanded');
        toggle.setAttribute('aria-expanded', String(expanded));
        document.body.style.overflow = expanded ? 'hidden' : '';
      });
    }

    // Close mobile menu on Escape
    header.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && header.classList.contains('expanded')) {
        header.classList.remove('expanded');
        toggle?.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
        (toggle as HTMLElement | null)?.focus();
      }
    });

    // Close on resize to desktop
    const mq = window.matchMedia('(min-width: 768px)');
    mq.addEventListener('change', (e) => {
      if (e.matches && header.classList.contains('expanded')) {
        header.classList.remove('expanded');
        toggle?.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      }
    });
  }
</script>
