---
import type { HTMLTag } from 'astro/types';
import type { Widget } from '~/types';
import { twMerge } from 'tailwind-merge';
import Background from './Background.astro';

export interface Props extends Widget {
  containerClass?: string;
  ['as']?: HTMLTag;
  /**
   * When true, emits intersection-observer fade-in classes.
   * Default false — opt-in, not on by default.
   * Breaking change vs 0.1.x: existing consumers that relied on the
   * auto-fade must now pass animate={true} explicitly.
   */
  animate?: boolean;
}

const { id, isDark = false, containerClass = '', bg, as = 'section', animate = false } = Astro.props;

const WrapperTag = as;

const animateClasses = animate
  ? 'intersect-once intersect-quarter intersect-no-queue motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade'
  : '';
---

<WrapperTag class="relative not-prose scroll-mt-[72px]" {...id ? { id } : {}}>
  <div class="absolute inset-0 pointer-events-none -z-[1]" aria-hidden="true">
    <slot name="bg">
      {bg ? <Fragment set:html={bg} /> : <Background isDark={isDark} />}
    </slot>
  </div>
  <div
    class:list={[
      twMerge(
        `relative mx-auto max-w-7xl px-4 md:px-6 py-12 md:py-16 lg:py-20 text-default ${animateClasses}`,
        containerClass
      ),
      { dark: isDark },
    ]}
  >
    <slot />
  </div>
</WrapperTag>
