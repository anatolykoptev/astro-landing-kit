---
import '@fontsource-variable/spline-sans';
import '@fontsource-variable/jetbrains-mono';
---

<style is:inline>
  /* HIGH-1 fix: wrapped in the lowest-priority named layer (see
     src/design/theme-layers.css) so an opt-in theme.css import and/or the DESIGN.md
     integration always win, regardless of where they're rendered/imported relative to
     this component. */
  @layer landing-kit-defaults {
    :root {
      --aw-font-sans: 'Spline Sans Variable', ui-sans-serif, system-ui, sans-serif;
      --aw-font-serif: 'Spline Sans Variable', ui-serif, Georgia, serif;
      --aw-font-heading: 'JetBrains Mono Variable', ui-monospace, monospace;
      --aw-font-mono: 'JetBrains Mono Variable', ui-monospace, monospace;

      /* Kit-neutral defaults. Override these in your consumer's :root stylesheet.
         Previously these were hardcoded to AstroWind blue (rgb(1 97 239)) which
         leaked brand color into all consumers. Replaced with a neutral teal
         that consumers are expected to override via src/assets/styles/theme.css. */
      --aw-color-primary: rgb(16 185 129);
      --aw-color-secondary: rgb(5 150 105);
      --aw-color-accent: rgb(16 185 129);
      --aw-color-on-primary: oklch(0.99 0.005 265);
      --aw-color-focus-ring: var(--aw-color-primary);
      --aw-color-focus-offset: var(--aw-color-bg-page);
      --aw-color-border: rgb(16 16 16 / 25%);
      --aw-color-surface-hover: rgb(16 16 16 / 6%);

      /* Near-black / near-white, not pure #000/#fff — a faint cool tint
         (chroma 0.005-0.008, hue ~265) matching the kit's own dark-navy lean
         (see --aw-color-bg-page-dark below and the slate-family dark: classes
         used throughout the widgets). This is the kit's zero-config default —
         CustomStyles.astro, not src/assets/styles/theme.css (that file is an
         opt-in starter the build never imports on its own). */
      --aw-color-text-heading: oklch(0.22 0.006 265);
      --aw-color-text-default: rgb(16 16 16);
      --aw-color-text-muted: rgb(16 16 16 / 66%);
      --aw-color-bg-page: oklch(0.99 0.005 265);

      --aw-color-bg-page-dark: rgb(3 6 32);

      ::selection {
        background-color: lavender;
      }
    }

    .dark {
      --aw-font-sans: 'Spline Sans Variable', ui-sans-serif, system-ui, sans-serif;
      --aw-font-serif: 'Spline Sans Variable', ui-serif, Georgia, serif;
      --aw-font-heading: 'JetBrains Mono Variable', ui-monospace, monospace;
      --aw-font-mono: 'JetBrains Mono Variable', ui-monospace, monospace;

      --aw-color-primary: rgb(16 185 129);
      --aw-color-secondary: rgb(5 150 105);
      --aw-color-accent: rgb(16 185 129);

      --aw-color-text-heading: rgb(247, 248, 248);
      --aw-color-text-default: rgb(229 236 246);
      --aw-color-text-muted: rgb(229 236 246 / 66%);
      --aw-color-bg-page: rgb(3 6 32);
      --aw-color-border: rgb(229 236 246 / 28%);
      --aw-color-surface-hover: rgb(229 236 246 / 10%);

      ::selection {
        background-color: rgb(3 6 32);
        color: snow;
      }
    }
  }
</style>
