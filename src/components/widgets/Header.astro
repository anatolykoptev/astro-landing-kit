---
import { Icon } from 'astro-icon/components';
import Logo from '~/components/Logo.astro';
import ThemeToggle from '~/components/islands/ThemeToggle.svelte';
import ToggleMenu from '~/components/common/ToggleMenu.astro';
import Button from '~/components/ui/Button.astro';

import { getHomePermalink } from '~/utils/permalinks';
import { trimSlash, getAsset } from '~/utils/permalinks';
import type { CallToAction } from '~/types';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface MenuLink extends Link {
  links?: Array<MenuLink>;
}

export interface Props {
  id?: string;
  links?: Array<MenuLink>;
  actions?: Array<CallToAction>;
  isSticky?: boolean;
  isDark?: boolean;
  isFullWidth?: boolean;
  showToggleTheme?: boolean;
  showRssFeed?: boolean;
  position?: string;
  navAriaLabel?: string;
  toggleMenuLabel?: string;
  rssAriaLabel?: string;
}

const {
  id = 'header',
  links = [],
  actions = [],
  isSticky = false,
  isDark = false,
  isFullWidth = false,
  showToggleTheme = false,
  showRssFeed = false,
  position = 'center',
  navAriaLabel = 'Main navigation',
  toggleMenuLabel,
  rssAriaLabel = 'RSS Feed',
} = Astro.props;

const currentPath = `/${trimSlash(new URL(Astro.url).pathname)}`;
---

<header
  class:list={[
    { sticky: isSticky, relative: !isSticky, dark: isDark },
    'top-0 z-40 flex-none mx-auto w-full border-b border-hairline transition-[opacity] ease-in-out',
    isSticky && 'backdrop-blur-md bg-page/80',
  ]}
  {...isSticky ? { 'data-aw-sticky-header': true } : {}}
  {...id ? { id } : {}}
>
  <div
    class:list={[
      'relative text-default py-3 px-3 md:px-6 mx-auto w-full',
      {
        'md:flex md:justify-between': position !== 'center',
      },
      {
        'md:grid md:grid-cols-3 md:items-center': position === 'center',
      },
      {
        'max-w-7xl': !isFullWidth,
      },
    ]}
  >
    <div class:list={[{ 'mr-auto rtl:mr-0 rtl:ml-auto': position === 'right' }, 'flex justify-between']}>
      <a class="flex items-center" href={getHomePermalink()}>
        <Logo />
      </a>
      <div class="flex items-center md:hidden">
        <ToggleMenu label={toggleMenuLabel} />
      </div>
    </div>
    <nav
      class="items-center w-full md:w-auto hidden md:flex md:mx-5 text-default overflow-y-auto overflow-x-hidden md:overflow-visible md:justify-self-center"
      aria-label={navAriaLabel}
    >
      <ul
        class="flex flex-col md:flex-row md:self-center w-full md:w-auto text-xl md:text-sm tracking-tight font-medium md:justify-center"
      >
        {
          links.map(({ text, href, links, ariaLabel }) => (
            <li class={links?.length ? 'dropdown' : ''}>
              {links?.length ? (
                <>
                  <button
                    type="button"
                    class="hover:text-primary px-4 py-3 flex items-center whitespace-nowrap transition-colors"
                  >
                    {text}{' '}
                    <Icon name="tabler:chevron-down" class="w-3.5 h-3.5 ml-0.5 rtl:ml-0 rtl:mr-0.5 hidden md:inline" />
                  </button>
                  <ul class="dropdown-menu md:backdrop-blur-md rounded md:absolute pl-4 md:pl-0 md:hidden font-medium md:bg-card/95 md:min-w-[200px] drop-shadow-xl border border-hairline">
                    {links.map(({ text: text2, href: href2, ariaLabel: ariaLabel2 }) => (
                      <li>
                        <a
                          class:list={[
                            'first:rounded-t last:rounded-b md:hover:bg-surface hover:text-primary py-2 px-5 block whitespace-nowrap transition-colors',
                            { 'aw-link-active': href2 === currentPath },
                          ]}
                          href={href2}
                          aria-label={ariaLabel2}
                        >
                          {text2}
                        </a>
                      </li>
                    ))}
                  </ul>
                </>
              ) : (
                <a
                  class:list={[
                    'hover:text-primary px-4 py-3 flex items-center whitespace-nowrap transition-colors',
                    { 'aw-link-active': href === currentPath },
                  ]}
                  href={href}
                  aria-label={ariaLabel}
                >
                  {text}
                </a>
              )}
            </li>
          ))
        }
      </ul>
    </nav>
    <div
      class:list={[
        { 'ml-auto rtl:ml-0 rtl:mr-auto': position === 'left' },
        'hidden md:self-center md:flex items-center md:mb-0 fixed w-full md:w-auto md:static justify-end left-0 rtl:left-auto rtl:right-0 bottom-0 p-3 md:p-0 md:justify-self-end',
      ]}
    >
      <div class="items-center flex justify-between w-full md:w-auto gap-3">
        <div class="flex items-center gap-2">
          {showToggleTheme && <ThemeToggle client:load />}
          {
            showRssFeed && (
              <a
                class="text-muted hover:text-default hover:bg-surface focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/40 rounded-lg text-sm p-2 inline-flex items-center transition-colors"
                aria-label={rssAriaLabel}
                href={getAsset('/rss.xml')}
              >
                <Icon name="tabler:rss" class="w-5 h-5" />
              </a>
            )
          }
        </div>
        {
          actions?.length ? (
            <span class="ml-2 rtl:ml-0 rtl:mr-2">
              {actions.map((btnProps) => (
                <Button {...btnProps} class="ml-2 py-2.5 px-5 md:px-6 font-semibold shadow-none text-sm w-auto" />
              ))}
            </span>
          ) : (
            ''
          )
        }
      </div>
    </div>
  </div>
</header>
