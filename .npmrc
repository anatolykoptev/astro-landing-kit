# Expose Astro dependencies for `pnpm` users
shamefully-hoist=true
# The @astrolib family (seo) is unmaintained (last publish 2024-10) and
# declares peer astro <= ^5 while this kit is on astro 6 — strict npm
# resolution (npm ci) fails on ERESOLVE. The packages work fine on astro 6;
# until @astrolib/seo is replaced (tracked in the repo issues), accept
# legacy peer resolution. @astrolib/analytics was already inlined away.
legacy-peer-deps=true
