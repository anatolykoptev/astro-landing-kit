---
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Headline from '~/components/ui/Headline.astro';
import Image from '~/components/common/Image.astro';
import type { Gallery as Props } from '~/types';

const {
  title = await Astro.slots.render('title'),
  subtitle = await Astro.slots.render('subtitle'),
  tagline = await Astro.slots.render('tagline'),
  images = [],
  columns = 3,
  captions = false,
  layout = 'grid',
  lightbox = true,
  id,
  isDark = false,
  classes = {},
  bg = await Astro.slots.render('bg'),
} = Astro.props;

// Generate a unique gallery ID for PhotoSwipe targeting
const galleryId = `gallery-${id || Math.random().toString(36).slice(2, 9)}`;

const colsClass =
  columns === 2 ? 'sm:grid-cols-2' :
  columns === 4 ? 'sm:grid-cols-2 lg:grid-cols-4' :
  'sm:grid-cols-2 lg:grid-cols-3';

const masonryCols =
  columns === 2 ? 'sm:columns-2' :
  columns === 4 ? 'sm:columns-2 lg:columns-4' :
  'sm:columns-2 lg:columns-3';

const isMasonry = layout === 'masonry';
---

<WidgetWrapper id={id} isDark={isDark} containerClass={`max-w-6xl mx-auto ${classes?.container ?? ''}`} bg={bg}>
  <Headline title={title} subtitle={subtitle} tagline={tagline} />

  {images.length > 0 && (
    <div id={galleryId} class:list={[isMasonry ? '' : `grid grid-cols-1 gap-4 ${colsClass}`, isMasonry ? `${masonryCols} gap-4` : '']}>
      {images.map((img, i) => (
        <div class:list={[
          'group relative overflow-hidden rounded-lg shadow-md',
          isMasonry ? 'mb-4 break-inside-avoid' : '',
        ]}>
          {lightbox ? (
            <a
              href={typeof img.src === 'string' ? img.src : (img.src as any)?.src || '#'}
              data-pswp-width={1200}
              data-pswp-height={800}
              data-pswp-srcset={typeof img.src === 'string' ? undefined : undefined}
              class="block cursor-zoom-in"
              aria-label={img.alt ? `View: ${img.alt}` : 'View image'}
            >
              <Image
                src={img.src}
                alt={img.alt ?? ''}
                class:list={['w-full object-cover transition-transform duration-300 group-hover:scale-105', isMasonry ? '' : 'h-64']}
                widths={[400, 768]}
                sizes="(max-width: 640px) 100vw, 33vw"
                loading={i < 6 ? 'eager' : 'lazy'}
              />
            </a>
          ) : (
            <Image
              src={img.src}
              alt={img.alt ?? ''}
              class:list={['w-full object-cover transition-transform duration-300 group-hover:scale-105', isMasonry ? '' : 'h-64']}
              widths={[400, 768]}
              sizes="(max-width: 640px) 100vw, 33vw"
              loading={i < 6 ? 'eager' : 'lazy'}
            />
          )}
          {captions && img.alt && (
            <div class="absolute inset-0 flex items-end bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none">
              <p class="text-white text-sm p-4 translate-y-2 group-hover:translate-y-0 transition-transform duration-300">{img.alt}</p>
            </div>
          )}
        </div>
      ))}
    </div>
  )}
</WidgetWrapper>

{lightbox && images.length > 0 && (
  <script define:vars={{ galleryId }}>
    import PhotoSwipeLightbox from 'photoswipe/lightbox';
    import 'photoswipe/style.css';

    const lightbox = new PhotoSwipeLightbox({
      gallery: `#${galleryId}`,
      children: 'a',
      pswpModule: () => import('photoswipe'),
      bgOpacity: 0.9,
      showHideAnimationType: 'fade',
    });
    lightbox.init();
  </script>
)}
