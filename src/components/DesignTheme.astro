---
/**
 * Injects the DESIGN.md-generated theme overrides as an inline <style>.
 *
 * `designThemeCss` is empty by default (src/design/theme-source.ts); the design
 * integration (src/design/integration.ts) fills it at build time when a DESIGN.md is
 * present. This component MUST render immediately after <CustomStyles /> in Layout.astro
 * so its `--aw-color-*` overrides win by cascade order (CustomStyles defaults first,
 * DESIGN.md overrides after). When the integration is not mounted, `designThemeCss` is
 * '' and nothing is emitted.
 */
import { designThemeCss } from '~/design/theme-source';
---

{designThemeCss ? <style is:inline set:html={designThemeCss} /> : null}
