---
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Headline from '~/components/ui/Headline.astro';
import { Icon } from 'astro-icon/components';
import type { Steps as Props } from '~/types';

const {
  title = await Astro.slots.render('title'),
  subtitle = await Astro.slots.render('subtitle'),
  tagline = await Astro.slots.render('tagline'),
  items = [],
  id,
  isDark = false,
  classes = {},
  bg = await Astro.slots.render('bg'),
} = Astro.props;
---

<WidgetWrapper id={id} isDark={isDark} containerClass={`max-w-4xl ${classes?.container ?? ''}`} bg={bg}>
  <Headline title={title} subtitle={subtitle} tagline={tagline} classes={{ container: 'text-center', ...((classes?.headline as object) ?? {}) }} />
  <div class="space-y-6">
    {items.map(({ title, description, icon }, idx) => (
      <div class="pm7-card pm7-card--hoverable intersect-once motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
        <div class="pm7-card-body flex gap-6 items-start">
          <div class="flex-shrink-0 w-12 h-12 rounded-full flex items-center justify-center font-mono text-sm font-bold" style="background: var(--pm7-primary-light, rgba(16,185,129,0.12)); color: var(--pm7-primary); border: 1px solid color-mix(in srgb, var(--pm7-primary) 28%, transparent);">
            {icon ? <Icon name={icon} class="w-5 h-5" /> : <span>{String(idx + 1).padStart(2, '0')}</span>}
          </div>
          <div>
            <h3 class="pm7-card-title mb-2">{title}</h3>
            {description && <p class="pm7-card-description" set:html={description} />}
          </div>
        </div>
      </div>
    ))}
  </div>
</WidgetWrapper>
