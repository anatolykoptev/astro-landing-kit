---
import { fetchPosts, blogPostRobots } from '~/utils/blog';
import { isBlogEnabled, isBlogPostRouteEnabled } from '~/utils/blog';
import Layout from '~/layouts/PageLayout.astro';
import SinglePost from '~/components/blog/SinglePost.astro';
import RelatedPosts from '~/components/blog/RelatedPosts.astro';
import ToBlogLink from '~/components/blog/ToBlogLink.astro';
import { getCanonical, getPermalink } from '~/utils/permalinks';
import type { MetaData } from '~/types';

export async function getStaticPaths() {
  if (!isBlogEnabled || !isBlogPostRouteEnabled) return [];
  const posts = await fetchPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = post;

const metadata: MetaData = {
  title: post.title,
  description: post.excerpt,
  canonical: post.metadata?.canonical || getCanonical(getPermalink(post.permalink, 'post')),
  image: post.image,
  robots: blogPostRobots,
};
---

<Layout metadata={metadata}>
  <ToBlogLink />
  <SinglePost post={post} url={Astro.url}>
    <Content />
  </SinglePost>
  <RelatedPosts post={post} />
</Layout>
