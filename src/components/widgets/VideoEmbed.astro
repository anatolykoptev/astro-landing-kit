---
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Headline from '~/components/ui/Headline.astro';
import Button from '~/components/ui/Button.astro';
import { YouTube } from '@astro-community/astro-embed-youtube';
import { Vimeo } from '@astro-community/astro-embed-vimeo';
import type { VideoEmbed as Props } from '~/types';

const {
  title = await Astro.slots.render('title'),
  subtitle = await Astro.slots.render('subtitle'),
  tagline = await Astro.slots.render('tagline'),
  src = '',
  poster = '',
  aspectRatio = 'aspect-video',
  callToAction,
  privacy = true,
  posterQuality = 'high',
  playlabel = 'Play video',
  duration,
  uploadDate,
  videoDescription,
  id,
  isDark = false,
  classes = {},
  bg = await Astro.slots.render('bg'),
} = Astro.props;

// Detect provider from URL
const isYouTube = src.includes('youtube.com') || src.includes('youtu.be');
const isVimeo = src.includes('vimeo.com');
const isMP4 = src.endsWith('.mp4') || src.endsWith('.webm') || src.endsWith('.ogg');

// JSON-LD VideoObject for SEO
let jsonLd = '';
if (src && (isYouTube || isVimeo) && (uploadDate || duration || videoDescription)) {
  const videoObj: Record<string, unknown> = {
    '@context': 'https://schema.org',
    '@type': 'VideoObject',
    name: title || 'Video',
    thumbnailUrl: poster || (isYouTube ? `https://i.ytimg.com/vi/${src.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/)([\w-]+)/)?.[1] || ''}/hqdefault.jpg` : ''),
    uploadDate: uploadDate || undefined,
    duration: duration || undefined,
    description: videoDescription || undefined,
    contentUrl: src,
  };
  // Strip undefined values
  Object.keys(videoObj).forEach((k) => videoObj[k] === undefined && delete videoObj[k]);
  jsonLd = JSON.stringify(videoObj).replace(/<\//g, '<\\/');
}
---

<WidgetWrapper id={id} isDark={isDark} containerClass={`max-w-4xl mx-auto ${classes?.container ?? ''}`} bg={bg}>
  <Headline title={title} subtitle={subtitle} tagline={tagline} />

  {src && (
    <div class:list={['relative w-full rounded-xl overflow-hidden shadow-2xl', aspectRatio]}>
      {isMP4 ? (
        <video
          src={src}
          poster={poster || undefined}
          controls
          class="absolute inset-0 w-full h-full"
        />
      ) : isYouTube ? (
        <YouTube
          id={src}
          poster={poster || undefined}
          posterQuality={posterQuality}
          playlabel={playlabel}
          params={privacy ? 'nocookie=true' : undefined}
          class="absolute inset-0 w-full h-full lite-youtube"
        />
      ) : isVimeo ? (
        <Vimeo
          id={src}
          class="absolute inset-0 w-full h-full"
        />
      ) : (
        <iframe
          src={src}
          title={title || 'Video'}
          class="absolute inset-0 w-full h-full"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        />
      )}
    </div>
  )}

  {callToAction && (
    <div class="mt-8 text-center">
      <Button variant="primary" {...callToAction} />
    </div>
  )}
</WidgetWrapper>

{jsonLd && (
  <script type="application/ld+json" set:html={jsonLd} />
)}

<style>
  /* Ensure lite-youtube-embed fills the container */
  :global(lite-youtube) {
    width: 100%;
    height: 100%;
    border: 0;
  }
  :global(lite-youtube::after) {
    content: '';
    display: block;
    padding-bottom: calc(100% / (16 / 9));
  }
  :global(lite-youtube > iframe) {
    width: 100%;
    height: 100%;
  }
</style>
