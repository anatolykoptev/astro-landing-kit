{
  "name": "astro-landing-kit",
  "version": "0.5.3",
  "description": "Reusable Astro + Svelte landing page kit",
  "type": "module",
  "packageManager": "npm@11.6.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anatolykoptev/astro-landing-kit.git"
  },
  "homepage": "https://github.com/anatolykoptev/astro-landing-kit#readme",
  "bugs": "https://github.com/anatolykoptev/astro-landing-kit/issues",
  "license": "MIT",
  "files": [
    "src",
    "!src/**/*.test.ts",
    "!src/pages",
    "!src/content",
    "!src/content.config.ts",
    "README.md",
    "LICENSE.md",
    "CLAUDE.md",
    "AGENTS.md",
    "DESIGN.md"
  ],
  "types": "./src/adapters/types.ts",
  "exports": {
    "./layouts/PageLayout": "./src/layouts/PageLayout.astro",
    "./layouts/*": "./src/layouts/*.astro",
    "./widgets/*": "./src/components/widgets/*.astro",
    "./blog/*": "./src/components/blog/*.astro",
    "./ui/*": "./src/components/ui/*.astro",
    "./islands/*": "./src/components/islands/*.svelte",
    "./seo": "./src/seo/index.ts",
    "./adapters/json": "./src/adapters/json.ts",
    "./adapters/types": "./src/adapters/types.ts",
    "./adapters": "./src/adapters/index.ts",
    "./images": "./src/utils/images.ts",
    "./utils/blog": "./src/utils/blog.ts",
    "./utils/permalinks": "./src/utils/permalinks.ts",
    "./utils/utils": "./src/utils/utils.ts",
    "./types": "./src/types.d.ts",
    "./styles": "./src/assets/styles/tailwind.css",
    "./styles/*": "./src/assets/styles/*",
    "./design": "./src/design/index.ts",
    "./design/integration": "./src/design/integration.ts",
    "./sw": "./src/sw/integration.ts",
    "./config": "./src/config/index.ts",
    "./config/kit": "./src/config/kit.ts",
    "./integration/robots": "./src/integration/robots.ts",
    "./components/FontPreload": "./src/components/FontPreload.astro",
    "./components/*": "./src/components/*.astro",
    "./compose": "./src/compose/RenderSections.astro",
    "./compose/registry": "./src/compose/registry.ts",
    "./forms": "./src/forms/index.ts",
    "./forms/csrf": "./src/forms/csrf.ts",
    "./forms/rate-limit": "./src/forms/rate-limit.ts",
    "./forms/webhook": "./src/forms/webhook.ts",
    "./adapters/directus": "./src/adapters/directus.ts"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "test": "vitest run"
  },
  "dependencies": {
    "@astro-community/astro-embed-vimeo": "^0.3.12",
    "@astro-community/astro-embed-youtube": "^0.5.10",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/svelte": "^9.0.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/spline-sans": "^5.2.8",
    "@tailwindcss/typography": "^0.5.16",
    "astro": "^7.0.7",
    "astro-compress": "^2.4.1",
    "astro-icon": "^1.1.5",
    "astro-seo": "^1.1.0",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-svelte": "^8.6.0",
    "gsap": "^3.15.0",
    "limax": "^4.2.3",
    "lodash.merge": "^4.6.2",
    "photoswipe": "^5.4.4",
    "svelte": "^5.55.9",
    "tailwind-merge": "^3.6.0",
    "unpic": "^4.1.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdown-remark": "7.2.1",
    "@astrojs/mdx": "^7.0.2",
    "@iconify-json/tabler": "^1.2.20",
    "@tailwindcss/vite": "^4.3.0",
    "@types/lodash.merge": "^4.6.9",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "reading-time": "^1.5.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
