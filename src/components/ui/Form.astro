---
import type { Form as Props } from '~/types';
import Button from '~/components/ui/Button.astro';
import Input from '~/components/ui/Input.astro';
import Textarea from '~/components/ui/Textarea.astro';

const { inputs, textarea, disclaimer, button = 'Contact us', description = '', action, method = 'POST' } = Astro.props;
---

<form action={action} method={method} class="space-y-5">
  {/* Honeypot field — hidden from users, bots fill it; server should reject if non-empty */}
  <div class="hidden" aria-hidden="true">
    <label for="company-website">Website (leave empty)</label>
    <input
      type="text"
      id="company-website"
      name="company_website"
      tabindex="-1"
      autocomplete="off"
      aria-hidden="true"
    />
  </div>

  {
    inputs &&
      inputs.map(
        ({ type = 'text', name, label = '', autocomplete = 'on', placeholder = '' }) =>
          name && (
            <Input
              name={name}
              label={label}
              type={type}
              autocomplete={autocomplete}
              placeholder={placeholder}
            />
          )
      )
  }

  {
    textarea && (
      <Textarea
        name={textarea.name ? textarea.name : 'message'}
        label={textarea.label}
        placeholder={textarea.placeholder}
        rows={textarea.rows ? textarea.rows : 4}
      />
    )
  }

  {
    disclaimer && (
      <div class="flex items-start">
        <div class="flex mt-0.5">
          <input
            id="disclaimer"
            name="disclaimer"
            type="checkbox"
            class="cursor-pointer h-4 w-4 rounded border-hairline text-primary focus:ring-primary"
          />
        </div>
        <div class="ml-3">
          <label for="disclaimer" class="cursor-pointer select-none text-sm text-muted">
            {disclaimer.label}
          </label>
        </div>
      </div>
    )
  }

  {
    button && (
      <div class="grid">
        <Button variant="primary" type="submit">
          {button}
        </Button>
      </div>
    )
  }

  {
    description && (
      <div class="text-center">
        <p class="text-sm text-muted">{description}</p>
      </div>
    )
  }
</form>
