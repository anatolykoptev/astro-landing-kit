---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/widgets/Header.astro';
import Footer from '~/components/widgets/Footer.astro';
import Announcement from '~/components/widgets/Announcement.astro';

import { headerData, footerData } from '~/navigation';

import type { MetaData } from '~/types';

export interface Props {
  metadata?: MetaData;
  disableDefaultFooter?: boolean;
  disableDefaultHeader?: boolean;
  disableDefaultAnnouncement?: boolean;
}

const {
  metadata,
  disableDefaultFooter = false,
  disableDefaultHeader = false,
  disableDefaultAnnouncement = false,
} = Astro.props;
---

<Layout metadata={metadata}>
  <slot name="announcement">
    {!disableDefaultAnnouncement && <Announcement />}
  </slot>
  <slot name="header">
    {!disableDefaultHeader && <Header {...headerData} isSticky showRssFeed showToggleTheme />}
  </slot>
  <main>
    <slot />
  </main>
  <slot name="footer">
    {!disableDefaultFooter && <Footer {...footerData} />}
  </slot>
</Layout>
