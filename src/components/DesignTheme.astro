---
/**
 * Injects the DESIGN.md-generated theme overrides as an inline <style>.
 *
 * `designThemeCss` is empty by default (src/design/theme-source.ts); the design
 * integration (src/design/integration.ts) fills it at build time when a DESIGN.md is
 * present, already wrapped in the `landing-kit-design-theme` cascade layer — the
 * highest-priority layer declared by src/design/theme-layers.css. That layer priority
 * (not render/DOM order) is what guarantees this always wins over CustomStyles.astro's
 * defaults and an optionally-imported theme.css. When the integration is not mounted,
 * `designThemeCss` is '' and nothing is emitted.
 */
import { designThemeCss } from '~/design/theme-source';
---

{designThemeCss ? <style is:inline set:html={designThemeCss} /> : null}
