{
  "name": "@krolik/landing-kit",
  "version": "0.3.0",
  "description": "Reusable Astro + Svelte landing page kit",
  "type": "module",
  "types": "./src/adapters/types.ts",
  "exports": {
    "./layouts/PageLayout": "./src/layouts/PageLayout.astro",
    "./layouts/*": "./src/layouts/*.astro",
    "./widgets/*": "./src/components/widgets/*.astro",
    "./blog/*": "./src/components/blog/*.astro",
    "./ui/*": "./src/components/ui/*.astro",
    "./islands/*": "./src/components/islands/*.svelte",
    "./seo": "./src/seo/index.ts",
    "./adapters/json": "./src/adapters/json.ts",
    "./adapters/types": "./src/adapters/types.ts",
    "./adapters": "./src/adapters/index.ts",
    "./images": "./src/utils/images.ts",
    "./utils/blog": "./src/utils/blog.ts",
    "./utils/permalinks": "./src/utils/permalinks.ts",
    "./utils/utils": "./src/utils/utils.ts",
    "./types": "./src/types.d.ts",
    "./styles": "./src/assets/styles/tailwind.css",
    "./styles/*": "./src/assets/styles/*",
    "./design": "./src/design/index.ts",
    "./design/integration": "./src/design/integration.ts",
    "./sw": "./src/sw/integration.ts",
