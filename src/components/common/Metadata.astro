---
import merge from 'lodash.merge';
import { SEO } from 'astro-seo';

import type { Props as AstroSeoProps } from 'astro-seo';

import { SITE, METADATA, I18N } from 'astrowind:config';
import type { MetaData } from '~/types';
import { getCanonical } from '~/utils/permalinks';

import { adaptOpenGraphImages } from '~/utils/images';

export interface Props extends MetaData {
  dontUseTitleTemplate?: boolean;
}

const {
  title,
  ignoreTitleTemplate = false,
  canonical = String(getCanonical(String(Astro.url.pathname))),
  robots = {},
  description,
  openGraph = {},
  twitter = {},
} = Astro.props;

// Resolve flat, next-seo-shaped values first (precedence: page props > METADATA > default) —
// astro-seo's Props are nested (openGraph.basic/.optional/.image), so the flat intermediate is
// adapted into that shape below, after image optimization.
const resolved = merge(
  {
    title: '',
    titleTemplate: '%s',
    canonical: canonical,
    noindex: true,
    nofollow: true,
    description: undefined,
    openGraph: {
      url: canonical,
      siteName: SITE?.name,
      images: [],
      locale: I18N?.language || 'en',
      type: 'website',
    },
    twitter: {
      cardType: openGraph?.images?.length ? 'summary_large_image' : 'summary',
    },
  },
  {
    title: METADATA?.title?.default,
    titleTemplate: METADATA?.title?.template,
    noindex: typeof METADATA?.robots?.index !== 'undefined' ? !METADATA.robots.index : undefined,
    nofollow: typeof METADATA?.robots?.follow !== 'undefined' ? !METADATA.robots.follow : undefined,
    description: METADATA?.description,
    openGraph: METADATA?.openGraph,
    twitter: METADATA?.twitter,
  },
  {
    title: title,
    titleTemplate: ignoreTitleTemplate ? '%s' : undefined,
    canonical: canonical,
    noindex: typeof robots?.index !== 'undefined' ? !robots.index : undefined,
    nofollow: typeof robots?.follow !== 'undefined' ? !robots.follow : undefined,
    description: description,
    openGraph: { url: canonical, ...openGraph },
    twitter: twitter,
  }
);

const adaptedOpenGraph = await adaptOpenGraphImages({ images: resolved.openGraph?.images ?? [] }, Astro.site);
const [primaryImage] = adaptedOpenGraph.images ?? [];

// astro-seo throws if `openGraph` is passed without `basic.title`/`basic.type`/`basic.image` —
// only emit the openGraph prop once we actually have an image to point `basic.image` at.
const seoOpenGraph = primaryImage?.url
  ? {
      basic: {
        title: resolved.title || SITE?.name || '',
        type: resolved.openGraph.type || 'website',
        image: primaryImage.url,
        url: resolved.openGraph.url,
      },
      image: {
        width: primaryImage.width,
        height: primaryImage.height,
      },
      optional: {
        description: resolved.description,
        siteName: resolved.openGraph.siteName,
        locale: resolved.openGraph.locale,
      },
    }
  : undefined;

const seoProps: AstroSeoProps = {
  title: resolved.title,
  titleTemplate: resolved.titleTemplate,
  canonical: resolved.canonical,
  noindex: resolved.noindex,
  nofollow: resolved.nofollow,
  description: resolved.description,
  openGraph: seoOpenGraph,
  twitter: {
    // next-seo-shaped `handle`/`site` map onto astro-seo's `creator`/`site`.
    card: resolved.twitter?.cardType,
    site: resolved.twitter?.site,
    creator: resolved.twitter?.handle,
  },
};
---

<SEO {...seoProps} />
