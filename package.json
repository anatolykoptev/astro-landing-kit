    "gsap": "^3.15.0",
    "js-yaml": "^4.1.0",
    "limax": "^4.2.3",
    "lodash.merge": "^4.6.2",
    "svelte": "^5.55.9",
    "tailwind-merge": "^2.6.0",
    "unpic": "^4.1.3"
