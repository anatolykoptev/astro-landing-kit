---
import { Icon } from 'astro-icon/components';
import { twMerge } from 'tailwind-merge';
import type { CallToAction as Props } from '~/types';

const {
  variant = 'secondary',
  target,
  text = Astro.slots.render('default'),
  icon = '',
  class: className = '',
  type,
  ...rest
} = Astro.props;

const variants = {
  primary: 'pm7-button pm7-button--primary pm7-button--on-dark',
  secondary: 'pm7-button pm7-button--secondary',
  tertiary: 'pm7-button pm7-button--ghost',
  link: 'pm7-button pm7-button--link',
};
---

{
  type === 'button' || type === 'submit' || type === 'reset' ? (
    <button type={type} class={twMerge(variants[variant] || 'pm7-button', className)} {...rest}>
      <Fragment set:html={text} />
      {icon && <Icon name={icon} class="w-5 h-5 ml-1 -mr-1.5 inline-block" />}
    </button>
  ) : (
    <a class={twMerge(variants[variant] || 'pm7-button', className)} {...(target ? { target, rel: 'noopener noreferrer' } : {})} {...rest}>
      <Fragment set:html={text} />
      {icon && <Icon name={icon} class="w-5 h-5 ml-1 -mr-1.5 inline-block" />}
    </a>
  )
}
