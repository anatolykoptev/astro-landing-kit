---
// MAJOR-2: theme-layers.css declares the --aw-color-* cascade-layer priority order
// (landing-kit-defaults < landing-kit-theme-starter < landing-kit-design-theme). It MUST
// stay the FIRST stylesheet import in this file — moving it later risks one of those
// layer names being first-encountered elsewhere before this declaration runs, which
// would establish a different priority than intended. See src/design/README.md
// "Precedence" for exactly what this import order does and does not guarantee.
import '~/design/theme-layers.css';
import '~/assets/styles/tailwind.css';

import { I18N } from 'astrowind:config';

import CommonMeta from '~/components/common/CommonMeta.astro';
import Favicons from '~/components/Favicons.astro';
import CustomStyles from '~/components/CustomStyles.astro';
import DesignTheme from '~/components/DesignTheme.astro';
import ApplyColorMode from '~/components/common/ApplyColorMode.astro';
import Metadata from '~/components/common/Metadata.astro';
import SiteVerification from '~/components/common/SiteVerification.astro';
import Analytics from '~/components/common/Analytics.astro';
import BasicScripts from '~/components/common/BasicScripts.astro';

// Comment the line below to disable View Transitions
import { ClientRouter } from 'astro:transitions';

import type { MetaData as MetaDataType } from '~/types';

export interface Props {
  metadata?: MetaDataType;
}

const { metadata = {} } = Astro.props;
const { language, textDirection } = I18N;
---

<!doctype html>
<!-- fix(2026-07-13): dropped `class="2xl:text-[20px]"` -- unexamined AstroWind-fork
     artifact (present since the very first commit, 82ad2a1, never tested/documented
     as intentional). It bumped the ROOT font-size 16px->20px at any >=1536px viewport
     (Tailwind's `2xl` breakpoint), silently inflating every rem-based size on the page
     by 1.25x above that width -- including a consumer's own carefully-tuned type scale,
     which then renders 25% larger than authored with no visible cause in the consumer's
     own code. Real incident: starthey.com shipped a deliberate H2/H3/eyebrow rem-based
     type-scale reduction (DESIGN.md "Section tiers") that measured CORRECTLY in source
     but rendered UNCHANGED live at a 1728px viewport specifically because of this rule
     -- traced via computed-style diffing (html font-size: 20px at 1728px vs 16px at
     1280px/390px) before finding this line. No prop/config exposed it, so a consumer
     had no way to override it short of a !important CSS fight. -->
<html lang={language} dir={textDirection}>
  <head>
    <CommonMeta />
    <Favicons />
    <CustomStyles />
    <!-- HIGH-2 fix: DesignTheme no longer depends on rendering after CustomStyles for
         correctness — theme-layers.css (imported above, first) pins DESIGN.md's cascade
         layer above CustomStyles' regardless of DOM order, so a future reorder here
         can't silently revert a branded consumer to the kit's teal defaults. Kept after
         CustomStyles for readability only. No-op unless the design integration is
         mounted. -->
    <DesignTheme />
    <ApplyColorMode />
    <Metadata {...metadata} />
    <SiteVerification />
    <Analytics />

    <link rel="preconnect" href="https://images.unsplash.com" />

    <!-- Comment the line below to disable View Transitions -->
    <ClientRouter fallback="swap" />
  </head>

  <body class="antialiased text-default bg-page tracking-tight">
    <slot />

    <BasicScripts />
  </body>
</html>
