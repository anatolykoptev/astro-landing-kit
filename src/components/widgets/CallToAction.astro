---
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import type { CallToAction, Widget } from '~/types';
import Headline from '~/components/ui/Headline.astro';
import Button from '~/components/ui/Button.astro';

interface Props extends Widget {
  title?: string;
  subtitle?: string;
  tagline?: string;
  callToAction?: CallToAction;
  actions?: string | CallToAction[];
  align?: 'left' | 'center';
}

const {
  title = await Astro.slots.render('title'),
  subtitle = await Astro.slots.render('subtitle'),
  tagline = await Astro.slots.render('tagline'),
  actions = await Astro.slots.render('actions'),
  align = 'center',

  id,
  isDark = false,
  classes = {},
  bg = await Astro.slots.render('bg'),
} = Astro.props;

const isLeft = align === 'left';
---

<WidgetWrapper id={id} isDark={isDark} containerClass={`max-w-6xl mx-auto ${classes?.container ?? ''}`} bg={bg}>
  <div
    class:list={[
      'max-w-3xl p-6 rounded-md shadow-xl dark:shadow-none dark:border dark:border-hairline',
      isLeft ? '' : 'mx-auto text-center',
    ]}
  >
    <Headline
      title={title}
      subtitle={subtitle}
      tagline={tagline}
      align={align}
      classes={{
        container: 'mb-0 md:mb-0',
        title: 'text-4xl md:text-4xl font-bold tracking-tighter mb-4 font-heading',
        subtitle: 'text-xl text-muted',
      }}
    />
    {
      actions && (
        <div
          class:list={[
            'max-w-xs sm:max-w-md m-auto flex flex-nowrap flex-col sm:flex-row gap-4 mt-6',
            isLeft ? 'sm:justify-start' : 'sm:justify-center',
          ]}
        >
          {Array.isArray(actions) ? (
            actions.map((action) => (
              <div class="flex w-full sm:w-auto">
                <Button {...(action || {})} class="w-full sm:mb-0" />
              </div>
            ))
          ) : (
            <Fragment set:html={actions} />
          )}
        </div>
      )
    }
  </div>
</WidgetWrapper>
